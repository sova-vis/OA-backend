# xAI / Grok API key
Grok_API=

# Optional xAI-compatible API key alias
XAI_API_KEY=

# xAI Responses API configuration
OA_GROK_BASE_URL=https://api.x.ai/v1
OA_GROK_MODEL=grok-4.20-reasoning
OA_GROK_OCR_SPLIT_TIMEOUT_SECONDS=180
OA_GROK_OCR_SPLIT_MAX_RETRIES=2
OA_ENABLE_AZURE_FALLBACK=true
OA_GROK_FALLBACK_OCR_THRESHOLD=0.90
OA_GROK_FALLBACK_SPLIT_THRESHOLD=0.92
OA_ENABLE_IMAGE_VARIANTS=true
OA_ENABLE_TARGETED_REPAIR=true
OA_ENGINE_DISAGREEMENT_THRESHOLD=0.08
OA_REPAIR_CONFIDENCE_THRESHOLD=0.85
OA_SELECTION_SCORE_MARGIN=0.05

# Azure Document Intelligence fallback OCR
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=
OA_AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30

# Review thresholds
OA_OCR_CONFIDENCE_THRESHOLD=0.85
OA_SPLIT_CONFIDENCE_THRESHOLD=0.90
OA_CLASSIFICATION_CONFIDENCE_THRESHOLD=0.80
