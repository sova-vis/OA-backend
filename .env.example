# Server Configuration
PORT=3001

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/jwks
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1

# Clerk Configuration
# Required for backend token verification and admin bootstrap scripts.
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev
# Optional when using direct public-key verification instead of issuer JWKS.
CLERK_JWT_KEY=

# Optional one-time bootstrap vars for admin creation script
ADMIN_BOOTSTRAP_EMAIL=sovavis2025@gmail.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeThisAdminPassword123!
ADMIN_BOOTSTRAP_NAME=Admin

# Database Configuration (Supabase connection string)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Optional: Node Environment
NODE_ENV=development
# Subject code → name overrides (for custom/internal codes not in the CAIE standard list)
# Format: CODE:Name,CODE:Name  (comma-separated, no spaces around colon)
# Example: SUBJECT_CODE_NAMES=1013:Islamiyat,1015:Pakistan Studies,1016:Physics,1017:Chemistry
# If not set, the system prefers the DB subject name, then CAIE code fallback.
# Check your server logs on startup — it will print "[RAG] Loaded subjects: code=name, ..." so you can verify.
SUBJECT_CODE_NAMES=

# Embeddings (query-time)
# Cohere key for query embeddings. Keep ingest and query embedding model aligned.
COHERE_API_KEY=your-cohere-key

# RAG context quality gates (if below threshold, system answers without citations)
MIN_BEST_SIMILARITY_FOR_CONTEXT=0.55
MIN_AVG_TOP3_SIMILARITY_FOR_CONTEXT=0.48
# Relaxed gates only when a subject filter is confidently inferred/applied
MIN_BEST_SIMILARITY_FOR_CONTEXT_WITH_SUBJECT=0.40
MIN_AVG_TOP3_SIMILARITY_FOR_CONTEXT_WITH_SUBJECT=0.34
# When metadata filters are present, query more embedding candidates before backend filtering
TOP_K_WITH_FILTERS=96
# Number of closest low-confidence papers to show when answer is not fully grounded
NEARBY_REFERENCE_LIMIT=4

# Groq API Key (FREE - for LLM answer generation)
# Get your API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here
# Current working models (gemma-7b-it is DEPRECATED and removed):
# llama-3.3-70b-versatile (best quality), llama3-8b-8192 (faster), mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# OA grading sidecar (Subject-Grading service)
# Preferred vars use OA_* naming. QA_* aliases are still supported for backward compatibility.
OA_GRADING_SERVICE_URL=http://127.0.0.1:8001
AUTO_START_OA_GRADING_SERVICE=true
# Optional explicit checkout path for the Python Subject-Grading repo.
# If unset, the launcher searches:
#   ../_ext/Subject-Grading
#   ../_ext/Subject Grading
#   ../Subject-Grading
#   ../Subject Grading
OA_GRADING_SERVICE_ROOT=

# Google Drive OAuth (optional)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-root-folder-id
# Legacy alias (optional). If both are set, GOOGLE_DRIVE_FOLDER_ID is used.
GOOGLE_DRIVE_ROOT_FOLDER_ID=
