# Server Configuration
PORT=3001

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/jwks
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1

# Database Configuration (Supabase connection string)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Optional: Node Environment
NODE_ENV=development
# Subject code → name overrides (for custom/internal codes not in the CAIE standard list)
# Format: CODE:Name,CODE:Name  (comma-separated, no spaces around colon)
# Example: SUBJECT_CODE_NAMES=1013:Islamiyat,1015:Pakistan Studies,1016:Physics,1017:Chemistry
# If not set, the system auto-guesses from a built-in CAIE code map.
# Check your server logs on startup — it will print "[RAG] Loaded subjects: code=name, ..." so you can verify.
SUBJECT_CODE_NAMES=

# Embeddings (query-time)
# Primary (recommended for deploy): HuggingFace bge-m3
# Token: https://huggingface.co/settings/tokens
# Use a token with Inference Providers permission enabled.
# Keep this model aligned with ingest so retrieval quality stays high.
HUGGINGFACE_API_KEY=hf_your_token_here
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-m3
# Router base for Inference Providers task endpoints
HUGGINGFACE_ROUTER_BASE_URL=https://router.huggingface.co

# Optional secondary cloud fallback
JINA_API_KEY=

# Optional local fallback (disabled by default in production)
# Set true only if your deploy can actually reach an Ollama server.
ALLOW_OLLAMA_FALLBACK=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=bge-m3

# Groq API Key (FREE - for LLM answer generation)
# Get your API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here
# Current working models (gemma-7b-it is DEPRECATED and removed):
# llama-3.3-70b-versatile (best quality), llama3-8b-8192 (faster), mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Google Drive OAuth (optional)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_REFRESH_TOKEN=your-refresh-token